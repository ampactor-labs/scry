# === SERVER ===
PORT=3000
TOKENSAFE_URL=https://tokensafe-production.up.railway.app
TOKENSAFE_API_KEY=tks_...           # API key for proxying full checks
TREASURY_WALLET=                     # Solana wallet address receiving USDC payments
HELIUS_API_KEY=                      # For on-chain payment verification
TELEGRAM_BOT_TOKEN=                  # From @BotFather
TELEGRAM_WEBHOOK_SECRET=             # Optional — defaults to ACCESS_TOKEN_SECRET
SERVER_URL=http://localhost:3000     # Public URL (Railway sets this)
ACCESS_TOKEN_SECRET=                 # Random 32-byte hex for HMAC signing
DATABASE_PATH=./data/scry.db        # SQLite path (Railway: /data/scry.db)

# === WEB (prefix with VITE_ for client access) ===
VITE_TOKENSAFE_URL=https://tokensafe-production.up.railway.app
VITE_API_URL=http://localhost:3000
VITE_TREASURY_WALLET=                # Same as TREASURY_WALLET (public, used for payment instruction)
VITE_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
VITE_SOLANA_NETWORK=mainnet-beta     # or devnet for testing
VITE_PAYMENT_AMOUNT=1.5             # USDC per full report
